{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/*.{css,js,ico,png,jpg,jpeg,gif,svg,webp,woff,woff2,ttf,eot,map}"]
  },
  "mimeTypes": {
    ".json": "application/json"
  },
  "globalHeaders": {
    "cache-control": "no-cache"
  },
  "routes": [
    {
      "route": "/*",
      "headers": {
        "cache-control": "no-cache"
      }
    }
  ]
}
